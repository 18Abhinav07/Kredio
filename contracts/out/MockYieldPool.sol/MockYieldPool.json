                        "notice": "Claim all pending yield (accrued store + live since last settle).         Mints fresh mUSDC directly to `to` - works on testnet because         MockUSDC.mint() is permissionless."
                    },
                    "deposit(uint256)": {
                        "notice": "Deposit mUSDC principal. Caller must have approved this contract first."
                    },
                    "getStake(address)": {
                        "notice": "Full stake view for dashboards."
                    },
                    "pendingYield(address)": {
                        "notice": "Returns pending yield = stored accrued + live (since last settle)."
                    },
                    "setYieldRate(uint256)": {
                        "notice": "Update APY rate. Use 600 for 6% APY, 60000 for fast demo visibility."
                    },
                    "withdraw(address,uint256)": {
                        "notice": "Withdraw principal back to `to`. Does NOT auto-claim yield.         Any yield accumulated so far is locked into `accrued` and remains         claimable via claimYield() so no yield is ever silently lost."
                    }

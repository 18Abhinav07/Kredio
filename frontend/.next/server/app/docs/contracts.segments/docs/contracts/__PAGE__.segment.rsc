19:["$","p",null,{"children":["All contract ABIs are available in ",["$","code",null,{"children":"frontend/lib/constants.ts"}]," and addresses are centralised in ",["$","code",null,{"children":"frontend/config/contracts.ts"}],", keyed by Chain ID. The ",["$","code",null,{"children":"useProtocolData"}]," and ",["$","code",null,{"children":"useProtocolActions"}]," hooks cover the full set of read and write operations for all user-facing contracts."]}]
1a:["$","pre",null,{"children":["$","code",null,{"children":"// Read all protocol state in a single batched RPC call\nconst {\n  creditScore, creditTier, collateralRatio, interestRate,\n  healthRatio, lendingPosition, borrowPosition,\n  pasPrice, protocolTotals,\n} = useProtocolData()\n\n// Execute any protocol action\nconst { deposit, borrow, repay, liquidate, swap } = useProtocolActions()"}]}]
